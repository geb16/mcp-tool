APP_ENV=dev
LOG_LEVEL=INFO

OPENAI_API_KEY=your_openai_api_key

MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080

# Use either MCP_API_KEY (single) or MCP_API_KEYS (comma-separated).
MCP_API_KEY=replace_me_for_remote_http
MCP_API_KEYS=

REQUIRE_TENANT_HEADER=true
DEFAULT_TENANT_ID=tenant-a

RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60

REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=60

DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/mcp_enterprise
DB_ECHO_SQL=false
SEED_DEMO_DATA=true

RBAC_READ_ROLES=viewer,support_agent,support_manager,admin
RBAC_WRITE_ROLES=support_manager,admin

ORDERS_WRITE_ENABLED=true
